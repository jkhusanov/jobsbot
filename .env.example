# --- Required ---
BOT_TOKEN=PASTE_YOUR_BOT_TOKEN_HERE
JOBS_API_URL=https://your-api.example.com/jobs

# Numeric chat id of the admin user / group / channel that receives applications.
# Leave at 0 the first time, send /start to the bot from the admin account,
# read the chat_id from the bot logs, paste it here, then restart.
ADMIN_CHAT_ID=0

# --- Optional ---
# If your jobs API requires auth, set the full Authorization header value:
#   JOBS_API_AUTH_HEADER=Bearer xxxxx
JOBS_API_AUTH_HEADER=

JOBS_API_TIMEOUT_SECONDS=10
JOBS_CACHE_TTL_SECONDS=60

# Display-only (shown in /start and logs); does NOT control delivery.
ADMIN_USERNAME=

DATABASE_PATH=./bot.db
MAX_CV_SIZE_MB=20
LOG_LEVEL=INFO
